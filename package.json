{
  "name": "lifeos",
  "private": true,
  "workspaces": ["packages/*", "infra", "ai-gateway"],
  "scripts": {
    "dev": "concurrently -n convex,web -c blue,green \"npx convex dev\" \"bun --filter @lifeos/dashboard dev\"",
    "dev:convex": "npx convex dev",
    "dev:dashboard": "bun --filter @lifeos/dashboard dev",
    "cli": "bun run packages/cli/src/index.ts",
    "build": "turbo build",
    "check": "turbo check",
    "test": "turbo test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/stripe": "^0.1.3",
    "convex": "^1.34.0",
    "stripe": "^20.3.1",
    "zod": "^4.3.6"
  }
}
