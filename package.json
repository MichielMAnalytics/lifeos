{
  "name": "lifeos",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently -n convex,web -c blue,green \"npx convex dev\" \"pnpm --filter @lifeos/dashboard dev\"",
    "dev:convex": "npx convex dev",
    "dev:dashboard": "pnpm --filter @lifeos/dashboard dev",
    "build": "turbo build",
    "check": "turbo check",
    "test": "turbo test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.34.0"
  }
}
